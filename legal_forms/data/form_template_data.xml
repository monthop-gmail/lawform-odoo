        <!-- แบบ ๑ หนังสือมอบอำนาจ -->
        <record id="template_power_of_attorney" model="legal.form.template">
            <field name="name">หนังสือมอบอำนาจ</field>
            <field name="code">แบบ ๑</field>
            <field name="category_id" ref="category_general"/>
            <field name="case_type">all</field>
            <field name="sequence">1</field>
            <field name="description">หนังสือมอบอำนาจทั่วไป สำหรับมอบอำนาจดำเนินคดีหรือกระทำการแทน</field>
            <field name="body_html"><![CDATA[
<div style="font-family: 'TH SarabunPSK', 'TH Sarabun New', sans-serif; font-size: 16pt; line-height: 1.8; max-width: 18cm; margin: auto;">

    <p style="text-align: center; font-size: 20pt; font-weight: bold;">หนังสือมอบอำนาจ</p>

    <p style="text-align: right;">
        เขียนที่ .......................................................
        <br/>
        วันที่ ......... เดือน ............................ พ.ศ. ...............
    </p>

    <p style="text-indent: 2.5cm;">
        โดยหนังสือฉบับนี้ ข้าพเจ้า ............................................................
        อายุ ............. ปี
        เลขประจำตัวประชาชน .............................................................
        อยู่บ้านเลขที่ .................. หมู่ที่ .............. ตรอก/ซอย ...............................
        ถนน ......................................... ตำบล/แขวง ............................................
        อำเภอ/เขต ........................................ จังหวัด ............................................
        โทรศัพท์ ............................................
    </p>

    <p style="text-indent: 2.5cm;">
        ขอมอบอำนาจให้ ............................................................
        อายุ ............. ปี
        เลขประจำตัวประชาชน .............................................................
        อยู่บ้านเลขที่ .................. หมู่ที่ .............. ตรอก/ซอย ...............................
        ถนน ......................................... ตำบล/แขวง ............................................
        อำเภอ/เขต ........................................ จังหวัด ............................................
        โทรศัพท์ ............................................
    </p>

    <p style="text-indent: 2.5cm;">
        เป็นผู้มีอำนาจกระทำการแทนข้าพเจ้า ในเรื่อง ............................................................
        ............................................................................................................................
        ............................................................................................................................
        ............................................................................................................................
    </p>

    <p style="text-indent: 2.5cm;">
        ทั้งนี้ ให้ผู้รับมอบอำนาจมีอำนาจกระทำการดังกล่าวข้างต้นแทนข้าพเจ้าได้ทุกประการ
        และการใดที่ผู้รับมอบอำนาจได้กระทำไปตามหนังสือมอบอำนาจนี้
        ให้ถือเสมือนว่าข้าพเจ้าได้กระทำด้วยตนเองทุกประการ
    </p>

    <br/><br/>

    <table style="width: 100%;">
        <tr>
            <td style="width: 50%;"></td>
            <td style="text-align: center;">
                ลงชื่อ ................................................ ผู้มอบอำนาจ
                <br/>
                ( ................................................ )
            </td>
        </tr>
        <tr>
            <td></td>
            <td style="text-align: center;">
                <br/>
                ลงชื่อ ................................................ ผู้รับมอบอำนาจ
                <br/>
                ( ................................................ )
            </td>
        </tr>
        <tr>
            <td></td>
            <td style="text-align: center;">
                <br/>
                ลงชื่อ ................................................ พยาน
                <br/>
                ( ................................................ )
            </td>
        </tr>
        <tr>
            <td></td>
            <td style="text-align: center;">
                <br/>
                ลงชื่อ ................................................ พยาน
                <br/>
                ( ................................................ )
            </td>
        </tr>
    </table>

    <br/>
    <p style="font-size: 12pt; color: #666;">
        หมายเหตุ: ปิดอากรแสตมป์ 10 บาท
    </p>
</div>
            ]]></field>
        </record>

